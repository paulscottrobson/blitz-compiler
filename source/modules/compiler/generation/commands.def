GO 				X:CommandGOAlt N
GOTO 			X:CommandGOTO N
GOSUB 			X:CommandGOSUB N
LET 			X:CommandLET N
PRINT 			X:CommandPRINT N
IF 				# X:CommandIF N

RETURN 			T N
STOP 			T N
END 			T N

