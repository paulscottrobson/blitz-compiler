# *******************************************************************************************
# *******************************************************************************************
#
#       Name :      commands.def
#       Purpose :   Command processor
#       Date :      16th April 2023
#       Author :    Paul Robson T(paul@robsons.org.uk)
#
# *******************************************************************************************
# *******************************************************************************************
#
#		Routines do all the work
#
GO 				X:CommandGOAlt N
GOTO 			X:CommandGOTO N
GOSUB 			X:CommandGOSUB N
LET 			X:CommandLET N
PRINT 			X:CommandPRINT N
REM 			X:CommandREM N
FOR 			X:CommandFOR N
NEXT 			X:CommandNEXT N
GET 			X:CommandGET N
DATA 			X:CommandDATA N
READ 			X:CommandREAD N
#
#		Routine supported
#
IF 				# X:CommandIF N
WAIT 			#,# X:CommandWAIT N
#
#		Controls
#
SYS 			# T N
POKE 			#,# T N
#
#		Token only
#
RETURN 			T N
STOP 			T N
END 			T N
RESTORE 		T N

