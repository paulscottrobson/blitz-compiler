.0807	49 80		eor #$80			eor 	#$80
.0809	95 30		sta $30,x			sta 	NSStatus,x					; and fall through.
.080b					FloatAdd:
.080b	ca		dex				dex
.080c	b5 6c		lda $6c,x			lda 	NSExponent,x 				; can use optimised.
.080e	15 6d		ora $6d,x			ora 	NSExponent+1,x
.0810	15 60		ora $60,x			ora 	NSMantissa3,x
.0812	15 61		ora $61,x			ora 	NSMantissa3+1,x
.0814	d0 04		bne $081a			bne 	_FAUseFloat
.0816	20 a4 19	jsr $19a4			jsr 	FloatInt32Add 				; use the int32 one.
.0819	60		rts				rts
.081a					_FAUseFloat:
.081a	20 a5 17	jsr $17a5			jsr 	FloatNormalise 				; normalise S[X]
.081d	f0 51		beq $0870			beq 	_FAReturn1
.081f	e8		inx				inx 								; normalise S[X+1]
.0820	20 a5 17	jsr $17a5			jsr 	FloatNormalise
.0823	ca		dex				dex
.0824	c9 00		cmp #$00			cmp 	#0
.0826	f0 60		beq $0888			beq 	_FAExit 					; if so, just return A
.0828	b5 6c		lda $6c,x			lda 	NSExponent,x 				; are the exponents the same ?
.082a	d5 6d		cmp $6d,x			cmp 	NSExponent+1,x
.082c	f0 18		beq $0846			beq 	_FAExponentsEqual
.082e	b5 6c		lda $6c,x			lda 	NSExponent,x 				; work out the larger exponent
.0830	a8		tay				tay
.0831	38		sec				sec 								; do a signed comparison of the exponents.
.0832	f5 6d		sbc $6d,x			sbc 	NSExponent+1,x
.0834	50 02		bvc $0838			bvc 	_FANoSignedChange
.0836	49 80		eor #$80			eor 	#$80
.0838					_FANoSignedChange:
.0838	29 80		and #$80			and 	#$80
.083a	10 02		bpl $083e			bpl 	_FAHaveMax
