.0841	e8		inx				inx
.0842	20 89 08	jsr $0889			jsr 	_FAShiftToExponent
.0845	ca		dex				dex
.0846					_FAExponentsEqual:
.0846	b5 30		lda $30,x			lda 	NSStatus,x 					; are the signs the same
.0848	55 31		eor $31,x			eor 	NSStatus+1,x
.084a	30 0e		bmi $085a			bmi 	_FADifferentSigns
.084c	20 70 19	jsr $1970			jsr 	FloatAddTopTwoStack 		; do the add of the mantissae
.084f	b5 60		lda $60,x			lda 	NSMantissa3,x 				; do we have an overflow in Mantissa A ?
.0851	10 35		bpl $0888			bpl 	_FAExit 					; if no, we are done.
