.0805					FloatSubtract:
.0805	b5 30		lda $30,x			lda 	NSStatus,x 					; negate top of stack
.0807	49 80		eor #$80			eor 	#$80
.0809	95 30		sta $30,x			sta 	NSStatus,x					; and fall through.
.080b					FloatAdd:
.080b	ca		dex				dex
.080c	b5 6c		lda $6c,x			lda 	NSExponent,x 				; can use optimised.
.080e	15 6d		ora $6d,x			ora 	NSExponent+1,x
.0810	15 60		ora $60,x			ora 	NSMantissa3,x
.0812	15 61		ora $61,x			ora 	NSMantissa3+1,x
.0814	d0 04		bne $081a			bne 	_FAUseFloat
.0816	20 cf 19	jsr $19cf			jsr 	FloatInt32Add 				; use the int32 one.
.0819	60		rts				rts
.081a					_FAUseFloat:
.081a	20 d0 17	jsr $17d0			jsr 	FloatNormalise 				; normalise S[X]
.081d	f0 51		beq $0870			beq 	_FAReturn1
.081f	e8		inx				inx 								; normalise S[X+1]
.0820	20 d0 17	jsr $17d0			jsr 	FloatNormalise
.0823	ca		dex				dex
.0824	c9 00		cmp #$00			cmp 	#0
.0826	f0 60		beq $0888			beq 	_FAExit 					; if so, just return A
.0828	b5 6c		lda $6c,x			lda 	NSExponent,x 				; are the exponents the same ?
.082a	d5 6d		cmp $6d,x			cmp 	NSExponent+1,x
.082c	f0 18		beq $0846			beq 	_FAExponentsEqual
.082e	b5 6c		lda $6c,x			lda 	NSExponent,x 				; work out the larger exponent
.0830	a8		tay				tay
.0831	38		sec				sec 								; do a signed comparison of the exponents.
.0832	f5 6d		sbc $6d,x			sbc 	NSExponent+1,x
.0834	50 02		bvc $0838			bvc 	_FANoSignedChange
.0836	49 80		eor #$80			eor 	#$80
.0838					_FANoSignedChange:
.0838	29 80		and #$80			and 	#$80
.083a	10 02		bpl $083e			bpl 	_FAHaveMax
.083c	b4 6d		ldy $6d,x			ldy 	NSExponent+1,x
.083e					_FAHaveMax:
.083e	20 89 08	jsr $0889			jsr 	_FAShiftToExponent  		; shift both to the exponent in Y
.0841	e8		inx				inx
.0842	20 89 08	jsr $0889			jsr 	_FAShiftToExponent
.0845	ca		dex				dex
.0846					_FAExponentsEqual:
.0846	b5 30		lda $30,x			lda 	NSStatus,x 					; are the signs the same
.0848	55 31		eor $31,x			eor 	NSStatus+1,x
.084a	30 0e		bmi $085a			bmi 	_FADifferentSigns
.084c	20 9b 19	jsr $199b			jsr 	FloatAddTopTwoStack 		; do the add of the mantissae
.084f	b5 60		lda $60,x			lda 	NSMantissa3,x 				; do we have an overflow in Mantissa A ?
.0851	10 35		bpl $0888			bpl 	_FAExit 					; if no, we are done.
.0853	20 c1 1c	jsr $1cc1			jsr 	FloatShiftRight 				; shift A right, renormalising it.
.0856	f6 6c		inc $6c,x			inc 	NSExponent,x 				; bump the exponent and exit
.0858	80 2e		bra $0888			bra 	_FAExit
.085a					_FADifferentSigns:
